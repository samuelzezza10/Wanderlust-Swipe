# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Use the Session Mode pooler URL from Supabase → Project → Settings → Database
# Session mode (port 5432 via pooler) supports prepared statements; use it for
# this Express/Drizzle app.  Do NOT use the direct connection (port 5432 on the
# db host) in serverless environments — it exhausts connection limits quickly.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
# API server (never exposed to the client)
CLERK_SECRET_KEY=sk_live_...

# Frontend build-time key (safe to commit to Vercel env)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk FAPI proxy — point it at your Vercel deployment's /api/__clerk path.
# Required for Clerk to work on custom domains.
# Set this AFTER you know your Vercel URL.
VITE_CLERK_PROXY_URL=https://your-app.vercel.app/api/__clerk

# ─── Google APIs ─────────────────────────────────────────────────────────────
# Server-side only — Gemini AI + Google Places fallback (never sent to client)
GOOGLE_API_KEY=AIza...

# Client-side only — Google Maps/Places (restrict this key by HTTP referrer in
# Google Cloud Console so it cannot be abused if seen in source)
VITE_GOOGLE_API_KEY=AIza...

# Optional: dedicated server-only key for Google Places API (hotel photos).
# Recommended setup: create a SEPARATE key in Google Cloud Console with
#   - API restriction: ONLY "Places API (New)" enabled
#   - Application restriction: "None" (or IP-restricted to your deploy IPs)
# This lets you keep GOOGLE_API_KEY locked to HTTP referrers for the web
# Maps SDK while server-side Places lookups still work.
GOOGLE_PLACES_API_KEY=

# Optional: only set if your Places key is referrer-restricted and you can't
# create an unrestricted server key. Must match an entry in the key's allowed
# referrer list, e.g. https://samuelzezza10.github.io/
GOOGLE_PLACES_REFERER=

# ─── Optional external APIs ──────────────────────────────────────────────────
# RapidAPI / Booking.com real-search integration (app falls back to mock data
# if these are absent — safe to leave unset)
RAPIDAPI_KEY=
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# Amadeus flight search (also optional — mock fires as fallback)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ─── Vercel / Production overrides ───────────────────────────────────────────
NODE_ENV=production

# If you deploy frontend and API as two separate Vercel projects, set this on
# the frontend project so API calls are routed to the correct URL.
# Leave unset for a single-project deployment (default).
# VITE_API_BASE_URL=https://your-api.vercel.app

# ─── Session / Security ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production
