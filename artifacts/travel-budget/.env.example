# ── Clerk Authentication (required) ──────────────────────────────────────────
# Create a free account at https://clerk.com and create a new application.
# Copy the publishable key from the Clerk dashboard > API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── API Server URL (optional) ─────────────────────────────────────────────────
# Leave empty when running the frontend and API server together locally.
# Set this to your deployed API URL when hosting the frontend separately
# (e.g. on GitHub Pages or Vercel static), pointing to your running API server.
# Example: https://your-api.your-user.replit.app
# VITE_API_BASE_URL=

# ── Clerk Proxy URL (optional) ────────────────────────────────────────────────
# Only needed when using Replit's Clerk proxy. Leave empty for standard setups.
# VITE_CLERK_PROXY_URL=

# ── Base Path (optional) ──────────────────────────────────────────────────────
# Set to /Wanderlust-Swipe/ when deploying to GitHub Pages.
# Leave empty (defaults to /) for local dev, Vercel, StackBlitz, etc.
# BASE_PATH=/

# ── Google Maps / Places API (optional, client-side) ─────────────────────────
# Used by `src/lib/google.ts` to lazy-load the Maps JS SDK + Places library.
# This value is INLINED into the static bundle — restrict the key in Google
# Cloud Console by HTTP referrer (your GitHub Pages domain) and by API
# (Maps JavaScript API + Places API only).
# In Replit dev it falls back to the GOOGLE_API_KEY Replit Secret automatically.
# In GitHub Actions, set VITE_GOOGLE_API_KEY as a repository secret.
# VITE_GOOGLE_API_KEY=AIza...

# ── Gemini AI (optional, SERVER ONLY — never in this file) ────────────────────
# Used by the API server (artifacts/api-server) via process.env.GOOGLE_API_KEY.
# DO NOT prefix with VITE_ — Gemini must never reach the client bundle.
