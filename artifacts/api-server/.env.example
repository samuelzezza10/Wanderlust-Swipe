# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Database (required) ───────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local: postgres://postgres:password@localhost:5432/wanderlust
# Neon / Supabase / Railway: copy the connection string from the dashboard.
DATABASE_URL=postgres://postgres:password@localhost:5432/wanderlust

# ── Clerk Authentication (required) ──────────────────────────────────────────
# Create a free account at https://clerk.com and create a new application.
# Copy the Secret Key from the Clerk dashboard > API Keys.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Publishable Key is needed here only for the Clerk proxy route.
# It must match the VITE_CLERK_PUBLISHABLE_KEY used in the frontend.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Session (required) ────────────────────────────────────────────────────────
# Any long random string — used to sign server-side session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_32_character_string

# ── Optional third-party APIs ─────────────────────────────────────────────────
# The app works without these — trips are AI-generated mock data.
# BOOKING_API_KEY=
# BOOKING_AFFILIATE_ID=
# SKYSCANNER_API_KEY=
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
